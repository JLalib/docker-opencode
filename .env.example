# OpenCode Docker Configuration
# -----------------------------------------------------------
# Imagen: smanx/opencode (soporta ARM64 / Raspberry Pi)
# Puerto por defecto de esta imagen: 4096
# -----------------------------------------------------------

# Puerto del servidor (default: 4096)
OPENCODE_PORT=4096

# Autenticación del servidor web (RECOMENDADO) Descomenta las 2 líneas siguientes si quieres activarlo, lo mismo en compose.yml
#OPENCODE_SERVER_USERNAME=opencode
#OPENCODE_SERVER_PASSWORD=password

# ============================================================
# Proveedor NVIDIA
# ============================================================
# Obtén tu API key gratis en: https://build.nvidia.com
# Los modelos nemotron y otros están disponibles sin coste
NVIDIA_API_KEY=TU-API-KEY
